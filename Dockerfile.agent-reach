ARG PYTHON_IMAGE=python:3.12-slim@sha256:090ba77e2958f6af52a5341f788b50b032dd4ca28377d2893dcf1ecbdfdfe203
FROM ${PYTHON_IMAGE}

WORKDIR /app

RUN pip install --no-cache-dir \
  starlette==1.1.0 \
  uvicorn==0.48.0 \
  httpx==0.28.1

COPY mcp_http_server.py /app/mcp_http_server.py

CMD ["python", "/app/mcp_http_server.py"]
