{
  "name": "prediction-market-proxy",
  "version": "2.0.0",
  "private": true,
  "description": "Serverless proxy for prediction-market APIs (Polymarket, Kalshi, SX Bet, Manifold). Deploy to Netlify, Vercel, Railway, or Render.",
  "scripts": {
    "test":             "node tests/proxy-core.test.js",
    "dev:netlify":      "netlify dev",
    "dev:vercel":       "vercel dev",
    "deploy:netlify":   "netlify deploy --prod --dir=public --functions=netlify/functions --no-build",
    "deploy:vercel":    "vercel --prod",
    "login:netlify":    "netlify login",
    "login:vercel":     "vercel login",
    "env:netlify":      "netlify env:list",
    "env:set:netlify":  "netlify env:set"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "netlify-cli": "^26.0.0",
    "vercel":       "^46.1.1"
  }
}
