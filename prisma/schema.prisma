generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TradingMode {
  DEMO
  PAPER
  LIVE
}

enum DataSource {
  MOCK
  REAL
}

enum ExecutionMode {
  SIMULATED
  REAL
}

enum OrderLifecycle {
  PLANNED
  SUBMITTED
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  FAILED
  EXPIRED
}

// ============ MARKETS ============

model Market {
  id            String   @id @default(cuid())
  externalId    String
  venue         String   // POLYMARKET | KALSHI | SX_BET | MANIFOLD
  title         String
  normalizedTitle String?
  titleHash     String?
  description   String?
  category      String   // politics, sports, crypto, science, etc.
  status        String   @default("ACTIVE") // ACTIVE, CLOSED, RESOLVED
  resolutionTime DateTime?
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  lastSnapshotAt    DateTime?
  latestPrice       Float?
  latestSpread      Float?
  latestLiquidity   Float?
  duplicateOf       String?
  duplicateStatus   String?
  lastResearchAt    DateTime?
  isActive      Boolean  @default(true)
  isClosed      Boolean  @default(false)
  isResolved    Boolean  @default(false)
  dataSource    DataSource @default(REAL)
  mode          TradingMode @default(PAPER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots        MarketSnapshot[]
  tradeCandidates  TradeCandidate[]
  candidateRuns    CandidateRun[]
  watchlistEntries Watchlist[]
  scanRuns         ScanRun[]
  researchRuns     ResearchRun[]
  decisions        Decision[]
  orders           Order[]
  positions        Position[]
  outcomes         Outcome[]
  postmortems Postmortem[]
  paperBets PaperBet[]
  walletTrades WalletTrade[]
  walletClusterSignals WalletClusterSignal[]
  ensemblePredictions EnsemblePrediction[]
  relatedAsA RelatedMarket[] @relation("RelatedA")
  relatedAsB RelatedMarket[] @relation("RelatedB")
  orderbookSnapshots OrderbookSnapshot[]
  clusterMarketLinks ClusterMarketLink[]
  oracleCheck OracleCheck?
  historicalSnapshots HistoricalSnapshot[]

  @@unique([venue, externalId])
}

model MarketSnapshot {
  id             String   @id @default(cuid())
  marketId       String
  market         Market   @relation(fields: [marketId], references: [id])
  venue          String?
  tokenId        String?
  noTokenId      String?
  price          Float?
  impliedProb    Float
  impliedProbability Float?
  liquidity      Float
  spread         Float
  spreadSource   String?
  volume24h      Float    @default(0)
  bestBid        Float?
  bestAsk        Float?
  bidDepth       Float?
  askDepth       Float?
  noBestBid      Float?
  noBestAsk      Float?
  noBidDepth     Float?
  noAskDepth     Float?
  priceImpact    Float?
  fillProbability Float?
  yesPrice       Float?
  noPrice        Float?
  orderBookDepth Float?
  rawJson        String?
  timestamp      DateTime @default(now())
  capturedAt     DateTime @default(now())

  @@index([marketId, capturedAt])
}

model ScanRun {
  id             String      @id @default(cuid())
  venue          String
  mode           TradingMode @default(PAPER)
  status         String      @default("PENDING")
  startedAt      DateTime    @default(now())
  finishedAt     DateTime?
  marketsFetched Int         @default(0)
  marketsCreated Int         @default(0)
  marketsUpdated Int         @default(0)
  marketsSkipped Int         @default(0)
  queuedCandidates Int       @default(0)
  errorMessage   String?
  cursorStart       String?
  cursorEnd         String?
  marketsFetchedNew Int         @default(0)
  repeatRate        Float?
  metadataJson      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  marketId       String?
  market         Market?     @relation(fields: [marketId], references: [id])
  candidateRuns  CandidateRun[]
  tradeCandidates TradeCandidate[]
}

model VenueCursor {
  id          String   @id @default(cuid())
  venue       String   @unique
  cursor      String?
  lastScanAt  DateTime?
  hasMore     Boolean  @default(false)
  metadataJson String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HistoricalSnapshot {
  id              String   @id @default(cuid())
  marketId        String
  market          Market   @relation(fields: [marketId], references: [id])
  price           Float
  impliedProb     Float
  liquidity       Float
  spread          Float
  volume24h       Float    @default(0)
  bestBid         Float?
  bestAsk         Float?
  snapshotTime    DateTime
  predictedProb   Float?
  walletSignalStrength Float?
  candidateScore  Float?
  createdAt       DateTime @default(now())

  @@index([marketId, snapshotTime])
}

// ============ TRADE CANDIDATES ============

model TradeCandidate {
  id            String   @id @default(cuid())
  marketId      String
  market        Market   @relation(fields: [marketId], references: [id])
  stage         String   @default("SCANNED") // SCANNED, TRIAGED, RESEARCHING, JUDGED, DECIDED, EXECUTED, SETTLED
  triageStatus  String?  // RELEVANT, IRRELEVANT, AMBIGUOUS
  triageReason  String?
  researchQueued Boolean  @default(false)
  lastProcessedAt DateTime?
  nextEligibleAt DateTime?
  processingLock String?
  lockExpiresAt  DateTime?
  retryCount     Int      @default(0)
  lastError      String?
  cooldownUntil      DateTime?
  lastDecisionAt     DateTime?
  lastResearchAt     DateTime?
  lastExecutionAt    DateTime?
  lastQueuedAt       DateTime?
  reprocessReason    String?
  sourceScanRunId String?
  sourceScanRun  ScanRun? @relation(fields: [sourceScanRunId], references: [id])
  candidateScore Float?
  adjustedEdge        Float?
  rawEdge             Float?
  edgeDirection       String?  // YES_EDGE | NO_EDGE | UNKNOWN — which side the edge favors
  biasAdjustedProb    Float?
  walletSignalScore   Float?
  walletSignalReason  String?
  relatedMarketSignal Float?
  oracleRiskPenalty   Float?
  correlationRiskPenalty Float?
  manipulationRiskPenalty Float?
  uncertaintyPenalty  Float?
  contradictionPenalty Float?
  acceptedCriteria    String?
  rejectedCriteria    String?
  skipReason          String?
  paperReturn         Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  decisions      Decision[]
  researchRuns   ResearchRun[]
  ensemblePredictions EnsemblePrediction[]

  @@unique([marketId])
  @@index([stage, nextEligibleAt])
}

model CandidateRun {
  id                     String    @id @default(cuid())
  marketId               String
  market                 Market    @relation(fields: [marketId], references: [id])
  scanRunId              String?
  scanRun                ScanRun?  @relation(fields: [scanRunId], references: [id])
  candidateScore         Float     @default(0)
  liquidityScore         Float     @default(0)
  spreadScore            Float     @default(0)
  volumeScore            Float     @default(0)
  freshnessScore         Float     @default(0)
  priceMoveScore         Float     @default(0)
  duplicatePenalty       Float     @default(0)
  stalePenalty           Float     @default(0)
  alreadyProcessedPenalty Float    @default(0)
  edgeScore               Float    @default(0)
  confidenceScore         Float    @default(0)
  sourceQualityScore      Float    @default(0)
  resolutionClarityScore  Float    @default(0)
  recencyScore            Float    @default(0)
  categoryPriorityScore   Float    @default(0)
  walletSignalScore       Float    @default(0)
  relatedMarketSignalScore Float   @default(0)
  uncertaintyPenalty      Float    @default(0)
  contradictionPenalty    Float    @default(0)
  oracleRiskPenalty       Float    @default(0)
  correlationRiskPenalty  Float    @default(0)
  manipulationRiskPenalty Float    @default(0)
  decision               String?
  reason                 String?
  nextEligibleAt         DateTime?
  createdAt              DateTime  @default(now())

  @@index([marketId, createdAt])
}

// ============ RESEARCH ============

model ResearchRun {
  id            String   @id @default(cuid())
  marketId      String
  market        Market   @relation(fields: [marketId], references: [id])
  candidateId   String?
  candidate     TradeCandidate? @relation(fields: [candidateId], references: [id])
  status        String   @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  depth         String   @default("QUICK")   // QUICK, DEEP, DEERFLOW
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sources      ResearchSource[]
  agentOutputs AgentOutput[]
  causalTreeNodes CausalTreeNode[]
}

model ResearchSource {
  id            String   @id @default(cuid())
  researchRunId String
  researchRun   ResearchRun @relation(fields: [researchRunId], references: [id])
  url           String
  title         String?
  content       String?
  sourceType    String   // SEARCH, CRAWL, SOCIAL, MANUAL
  recencyScore  Float?
  qualityScore  Float?
  extractedAt   DateTime @default(now())
}

// ============ AGENT OUTPUTS ============

model AgentOutput {
  id              String   @id @default(cuid())
  researchRunId   String
  researchRun     ResearchRun @relation(fields: [researchRunId], references: [id])
  role            String   // TRIAGE, BULL, BEAR, CONTRADICTION, JUDGE, etc.
  stage           String?  // Pipeline stage: TRIAGE, WEB_SEARCH, DEERFLOW, SYNTHESIS, etc.
  serviceName     String?  // Human-readable service name
  provider        String?  // Provider: openai, deerflow, tradingagents, agent_reach, system
  modelUsed       String?
  promptVersion   String?
  output          String   // JSON string of structured output
  rawOutput       String?  // Full raw output from the service
  summary         String?  // Human-readable summary
  referencesJson  String?  // JSON array of source references
  failureReason   String?  // Reason for failure if status is failed
  tokenCount      Int?
  latencyMs       Int?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime @default(now())
}

// ============ DECISIONS ============

model Decision {
  id              String   @id @default(cuid())
  marketId        String
  market          Market   @relation(fields: [marketId], references: [id])
  candidateId     String?
  candidate       TradeCandidate? @relation(fields: [candidateId], references: [id])
  action          String   // BID, SKIP, WATCH
  side            String?  // YES, NO
  reasonCode      String?  // LOW_LIQUIDITY, WIDE_SPREAD, etc.
  reason          String?
  judgeProbability Float?
  impliedProb     Float?
  edge            Float?
  confidence      Float?
  uncertainty     Float?
  maxSize         Float?
  urgency         String?  // LOW, MEDIUM, HIGH, IMMEDIATE
  fees            Float?
  slippage        Float?
  mode            TradingMode @default(PAPER)
  dataSource      DataSource  @default(REAL)
  executionMode   ExecutionMode @default(SIMULATED)
  dryRun          Boolean @default(true)
  brierScore      Float?
  paperBet        PaperBet?
  watchlistEntries Watchlist[]
  strategyConfigVersionId String?
  strategyConfigVersion   StrategyConfigVersion? @relation(fields: [strategyConfigVersionId], references: [id])
  createdAt       DateTime @default(now())

}

model Watchlist {
  id          String   @id @default(cuid())
  marketId    String
  market      Market   @relation(fields: [marketId], references: [id])
  decisionId  String?
  decision    Decision? @relation(fields: [decisionId], references: [id])
  reason      String?
  targetPrice Float?
  recheckAt   DateTime?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([marketId, status])
}

// ============ ORDERS ============

model Order {
  id            String   @id @default(cuid())
  marketId      String
  market        Market   @relation(fields: [marketId], references: [id])
  venueOrderId  String?
  executionMode ExecutionMode @default(SIMULATED)
  dataSource    DataSource @default(REAL)
  lifecycleStatus OrderLifecycle @default(PLANNED)
  side          String   // YES, NO
  price         Float
  size          Float
  filledSize    Float    @default(0)
  remainingSize Float    @default(0)
  avgFillPrice  Float?
  failureReason String?
  spreadCost      Float?
  slippageCost    Float?
  estimatedFillCost Float?
  status        String   @default("PENDING") // PENDING, SUBMITTED, PARTIAL, FILLED, CANCELLED, FAILED
  retryCount    Int      @default(0)
  fillAttemptCount Int   @default(0)
  lastFillAttemptAt DateTime?
  orderExpiryAt DateTime?
  fillModel     String?
  executionNotesJson String?
  submittedAt   DateTime?
  filledAt      DateTime?
  cancelledAt   DateTime?
  expiredAt     DateTime?
  strategyConfigVersionId String?
  strategyConfigVersion   StrategyConfigVersion? @relation(fields: [strategyConfigVersionId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  fills Fill[]
  paperBet PaperBet?

  @@index([lifecycleStatus, submittedAt])
}

model Fill {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  price         Float
  size          Float
  fee           Float
  fillModel     String?
  metadataJson  String?
  fillTime      DateTime @default(now())
}

// ============ POSITIONS ============

model Position {
  id            String   @id @default(cuid())
  marketId      String
  market        Market   @relation(fields: [marketId], references: [id])
  side          String
  entryPrice    Float
  currentSize   Float
  avgEntryPrice Float
  unrealizedPnl Float    @default(0)
  realizedPnl   Float    @default(0)
  status        String   @default("OPEN") // OPEN, WATCH, CLOSED
  openedAt      DateTime @default(now())
  closedAt      DateTime?

  @@index([marketId, side, status])
}

// ============ PAPER BETS (DRY-RUN TRACKING) ============

model PaperBet {
  id String @id @default(cuid())
  marketId String
  market Market @relation(fields: [marketId], references: [id])
  decisionId String @unique
  decision Decision @relation(fields: [decisionId], references: [id])
  orderId String? @unique
  order Order? @relation(fields: [orderId], references: [id])
  
  predictionType String // BID, WATCH
  setupType String? // A_PLUS_BET, STANDARD_BET
  aPlusStatus String? // PASSED, FAILED, HEURISTIC
  executionStatus String @default("SUBMITTED") // PLANNED, SUBMITTED, PARTIAL, FILLED, FAILED, EXPIRED
  executedAt DateTime?
  predictedProb Float // Model's probability estimate
  predictedSide String // YES, NO
  impliedProb Float // Market price at prediction time
  edge Float // predictedProb - impliedProb (or 1-implied for NO)
  confidence Float
  
  stake Float // Paper stake amount
  entryPrice Float // Price at which bet was "placed"
  
  // Resolution (filled when market resolves)
  actualOutcome String? // YES, NO, CANCELLED
  resolvedProb Float? // Final market probability at resolution
  resolvedAt DateTime?
  
  // Scoring
  directionCorrect Boolean? // Did we predict YES/NO correctly?
  probError Float? // |predictedProb - actualProb| or |predictedProb - resolvedProb|
  brierScore Float? // (predictedProb - actualProb)^2 where actualProb is 1 or 0
  pnl Float? // Simulated profit/loss
  
  // Metadata
  strategyConfigVersionId String?
  strategyConfigVersion   StrategyConfigVersion? @relation(fields: [strategyConfigVersionId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([marketId])
  @@index([predictionType])
  @@index([resolvedAt])
  @@index([executionStatus, resolvedAt])
}

// ============ OUTCOMES ============

model Outcome {
  id String @id @default(cuid())
  marketId String @unique
  market Market @relation(fields: [marketId], references: [id])
  result String // YES, NO, CANCELLED
  resolvedProb Float?
  resolvedAt DateTime @default(now())
}

// ============ POSTMORTEMS ============

model Postmortem {
  id            String   @id @default(cuid())
  marketId      String
  market        Market   @relation(fields: [marketId], references: [id])
  predictedProb Float?
  actualOutcome String?
  pnl           Float?
  lessons       String?
  failureTags   String?  // comma-separated tags
  createdAt     DateTime @default(now())
}

// ── WALLET INTELLIGENCE (Phase 5) ──
model Wallet {
  id            String   @id @default(cuid())
  address       String
  label         String?
  venue         String   @default("POLYMARKET")
  totalTrades   Int      @default(0)
  resolvedTrades Int     @default(0)
  activeDays    Int      @default(0)
  winRate       Float?
  profitFactor  Float?
  realizedPnl   Float    @default(0)
  brierScore    Float?
  categorySpecialization String?
  avgPositionSize Float?
  avgHoldTimeMs Int?
  drawdown      Float?
  jackpotDependency Float?
  reliabilityScore Float?
  recentPerformance Float?
  avgEdge       Float?
  rank          Int?
  isActive      Boolean  @default(true)
  lastActivityAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trades WalletTrade[]

  @@unique([venue, address])
}

model WalletTrade {
  id            String   @id @default(cuid())
  walletId      String
  wallet        Wallet   @relation(fields: [walletId], references: [id])
  marketId      String?
  market        Market?  @relation(fields: [marketId], references: [id])
  externalMarketId String?
  side          String
  quantity      Float
  price         Float
  tradeTimestamp DateTime
  category      String?
  resolutionDate DateTime?
  currentPosition Float?
  realizedPnl   Float?
  unrealizedPnl Float?
  sourceMode    String   @default("DISABLED")
  sourceName    String?
  trustedSource Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([walletId, tradeTimestamp])
  @@index([marketId])
  @@unique([walletId, externalMarketId, tradeTimestamp, side])
}

model WalletClusterSignal {
  id                 String   @id @default(cuid())
  marketId           String
  market             Market   @relation(fields: [marketId], references: [id])
  side               String   // YES, NO
  walletCount        Int
  trustedWalletCount Int
  combinedSize       Float
  detectedAt         DateTime @default(now())
  averageEntryPrice  Float
  priceAtDetection   Float
  spreadAtDetection  Float?
  liquidityAtDetection Float?
  copyLatePenalty    Float    @default(0)
  status             String   @default("DETECTED")
  paperResultJson    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([marketId])
  @@index([status])
}

model ModelRegistryRecord {
  id              String   @id @default(cuid())
  modelName       String
  version         String
  provider        String
  category        String
  enabled         Boolean  @default(true)
  fallbackPriority Int     @default(0)
  rollingBrier    Float?
  sampleSize      Int      @default(0)
  lastEvaluatedAt DateTime?
  weight          Float    @default(1.0)
  status          String   @default("TESTING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([modelName, version, category])
  @@index([category, status])
}

model EnsemblePrediction {
  id              String   @id @default(cuid())
  marketId        String
  market          Market   @relation(fields: [marketId], references: [id])
  candidateId     String?
  candidate       TradeCandidate? @relation(fields: [candidateId], references: [id])
  source          String
  predictedProb   Float
  confidence      Float?
  weight          Float    @default(1.0)
  brierScore      Float?
  category        String?
  createdAt       DateTime @default(now())

  @@index([marketId, source])
  @@index([candidateId])
}

model CorrelationCluster {
  id            String   @id @default(cuid())
  clusterType   String
  clusterKey    String
  label         String?
  exposureLimit Float?
  currentExposure Float  @default(0)
  maxLoss       Float?
  lossToWinRatio Float?
  tailRiskLevel String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  marketLinks ClusterMarketLink[]

  @@unique([clusterType, clusterKey])
}

model ClusterMarketLink {
  id            String   @id @default(cuid())
  clusterId     String
  cluster       CorrelationCluster @relation(fields: [clusterId], references: [id])
  marketId      String
  market        Market   @relation(fields: [marketId], references: [id])
  exposureWeight Float   @default(1.0)
  createdAt     DateTime @default(now())

  @@unique([clusterId, marketId])
}

model OracleCheck {
  id              String   @id @default(cuid())
  marketId        String
  market          Market   @relation(fields: [marketId], references: [id])
  oracleSource    String?
  resolutionCriteria String?
  resolutionDate  DateTime?
  timezone        String?
  ambiguousWording Boolean  @default(false)
  humanDiscretion Boolean  @default(false)
  appealProcess   Boolean  @default(false)
  crossVenueMismatch Boolean @default(false)
  riskLevel       String
  oracleRiskReasons String?
  manualReviewRequired Boolean @default(false)
  manualReviewStatus String   @default("NOT_REQUIRED")
  manualReviewRequestedAt DateTime?
  manualReviewRequestedBy String?
  manualReviewCompletedAt DateTime?
  manualReviewCompletedBy String?
  manualReviewNotes String?
  manualReviewExpiresAt DateTime?
  reviewDecision String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([marketId])
}


// ── CAUSAL TREE NODES (Phase 7) ──
model CausalTreeNode {
  id            String   @id @default(cuid())
  researchRunId String
  researchRun   ResearchRun @relation(fields: [researchRunId], references: [id])
  parentId      String?
  parent        CausalTreeNode? @relation("CausalTreeParent", fields: [parentId], references: [id])
  children      CausalTreeNode[] @relation("CausalTreeParent")
  label         String
  probability   Float?
  importanceWeight Float   @default(0)
  evidence      String?
  sourceQuality Float?
  confidence    Float?
  contradictions String?
  lastUpdated   DateTime @default(now())

  @@index([researchRunId])
}


// ── RELATED MARKETS (Phase 8) ──

model RelatedMarket {
  id              String   @id @default(cuid())
  marketIdA       String
  marketA         Market   @relation("RelatedA", fields: [marketIdA], references: [id])
  marketIdB       String
  marketB         Market   @relation("RelatedB", fields: [marketIdB], references: [id])
  relationshipType String
  relationshipConfidence Float?
  expectedRule   String?
  formulaVersion String?
  violationScore Float?
  violationSeverity String?
  action         String?
  explanation    String?
  oracleMismatchRisk Float?
  priceInconsistency Float?
  contradictionScore Float?
  possibleEdge    Float?
  alertText       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([marketIdA, marketIdB])
  @@index([marketIdA])
  @@index([marketIdB])
}

// ── STRATEGY CONFIG VERSIONS (Phase 16) ──
model StrategyConfigVersion {
  id              String   @id @default(cuid())
  version         Int
  name            String?
  config          String
  status          String   @default("DRAFT")
  dateRangeStart  DateTime?
  dateRangeEnd    DateTime?
  sampleSize      Int?
  aPlusWinRate    Float?
  aPlusROI        Float?
  brierScore      Float?
  drawdown        Float?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  backtestRuns    BacktestRun[]
  decisions       Decision[]
  orders          Order[]
  paperBets       PaperBet[]

  @@unique([version])
}

// ── BIAS MODEL VERSION (P1.9) ──
model BiasModelVersion {
  id                   String    @id @default(cuid())
  version              Int
  category             String
  probabilityBucketLow  Float
  probabilityBucketHigh Float
  sampleSize           Int
  observedFrequency    Float
  marketFrequency      Float
  wangLambda           Float
  offset               Float
  dateRangeStart       DateTime?
  dateRangeEnd         DateTime?
  status               String    @default("TESTING")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([version, category, probabilityBucketLow, probabilityBucketHigh])
  @@index([category, status])
}

// ── BACKTESTING (Phase 15) ──
model BacktestRun {
  id              String   @id @default(cuid())
  strategyConfigId String?
  strategyConfig  StrategyConfigVersion? @relation(fields: [strategyConfigId], references: [id])
  status          String   @default("PENDING")
  mode            String
  periodStart     DateTime
  periodEnd       DateTime
  totalMarkets    Int      @default(0)
  totalBets       Int      @default(0)
  winRate         Float?
  roi             Float?
  brierScore      Float?
  drawdown        Float?
  sharpeRatio     Float?
  result          String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
}


model OrderbookSnapshot {
  id            String   @id @default(cuid())
  marketId      String
  market        Market   @relation(fields: [marketId], references: [id])
  bestBid       Float?
  bestAsk       Float?
  spread        Float?
  spreadSource  String?
  orderbookSource String?
  bidDepth       Float?
  askDepth       Float?
  noBestBid      Float?
  noBestAsk      Float?
  noBidDepth     Float?
  noAskDepth     Float?
  depthImbalance Float?
  largeBidWall   Float?
  largeAskWall   Float?
  thinBookDanger Boolean  @default(false)
  priceImpact    Float?
  fillProbability Float?
  recentMovement Float?
  depthDecay     Float?
  rawJson       String?
  capturedAt     DateTime @default(now())

  @@index([marketId, capturedAt])
}


// ── RESEARCH CHECKPOINT (Phase 13) ──
model ResearchCheckpoint {
  id              String   @id @default(cuid())
  jobId           String   @unique
  job             Job      @relation(fields: [jobId], references: [id])
  state           String
  lastHeartbeatAt DateTime @default(now())
  createdAt       DateTime @default(now())
}

// ============ PROMPT TEMPLATES ============

model PromptTemplate {
  id            String   @id @default(cuid())
  name          String   // triage, bull, bear, contradiction, judge, postmortem
  version       Int      @default(1)
  state         String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  body          String
  description   String?
  changelog     String?
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, version])
}

// ============ CREDENTIALS ============

model Credential {
  id            String   @id @default(cuid())
  service       String   // polymarket, kalshi, gemini, openai, qdrant, mem0, ollama, searxng
  label         String
  encryptedData String   // encrypted JSON of credentials
  maskedPreview String?  // e.g. \"pk_****abcd\"
  serviceUrl    String?  // self-hosted service URL (e.g. http://localhost:6333)
  isActive      Boolean  @default(true)
  lastTestedAt  DateTime?
  testResult    String?  // SUCCESS, FAILED
  testDetails   String?  // details from last test (latency, version, etc.)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
model Settings {
  id                  String   @id @default(cuid())
  key                  String   @unique
  value                String   // JSON-encoded value
  description          String?
  updatedAt            DateTime @updatedAt
}


// ============ AUDIT LOGS ============

model AuditLog {
  id            String   @id @default(cuid())
  action        String
  actor         String?
  entityType    String?
  entityId      String?
  details       String?
  createdAt     DateTime @default(now())
}

model DecisionEventLedger {
  id            String   @id @default(cuid())
  correlationId String
  eventType     String
  stage         String?
  actor         String?
  payload       String
  prevHash      String?
  hash          String
  createdAt     DateTime @default(now())

  @@index([correlationId, createdAt])
  @@index([eventType, createdAt])
}

// ============ JOBS ============

model Job {
  id            String   @id @default(cuid())
  type          String   // SCAN, TRIAGE, RESEARCH, JUDGE, RISK, EXECUTE, SETTLE
  status        String   @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED, RETRYING
  priority      Int      @default(5)
  payload       String?  // JSON
  result        String?  // JSON
  retryCount    Int      @default(0)
  maxRetries    Int      @default(3)
  nextRetryAt     DateTime?
  lockExpiresAt   DateTime?
  heartbeatAt     DateTime?
  maxRuntimeSec   Int      @default(300)
  dedupKey        String?
  dependencyJobId String?
  progress        Float?
  startedAt     DateTime?
  completedAt   DateTime?
  error         String?
  researchCheckpoints ResearchCheckpoint[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

}
