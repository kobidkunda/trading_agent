{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "firecrawl": {
      "command": [
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "enabled": true,
      "environment": {
        "FIRECRAWL_API_URL": "http://192.168.88.97:4565"
      },
      "type": "local"
    },
    "mempalace": {
      "command": [
        "/Users/biolastic/.local/pipx/venvs/mempalace/bin/python",
        "-m",
        "mempalace.mcp_server"
      ],
      "enabled": true,
      "type": "local"
    },
    "netlify": {
      "command": [
        "npx",
        "-y",
        "@netlify/mcp"
      ],
      "enabled": true,
      "environment": {
        "NETLIFY_PERSONAL_ACCESS_TOKEN": "REPLACE_WITH_YOUR_NETLIFY_TOKEN"
      },
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "searxng": {
      "command": [
        "npx",
        "-y",
        "mcp-searxng"
      ],
      "enabled": true,
      "type": "local"
    },
    "stitch": {
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "REPLACE_WITH_YOUR_GCP_API_KEY"
      },
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp"
    }
  },
  "permission": {
    "*": "allow"
  },
  "plugin": [
    "/Users/biolastic/.config/opencode/plugins/firecrawl.ts",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "oh-my-openagent@latest"
  ],
